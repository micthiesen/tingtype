#!/usr/bin/env bash
set -euo pipefail

# Resolve through symlinks (this is symlinked into ~/.local/bin by install.sh).
REPO_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$REPO_DIR/scripts/_common.sh"
BUN="$(resolve_bun)" || { echo "bun not found" >&2; exit 127; }

cmd="${1:-}"

case "$cmd" in
  install|start|stop|restart|deploy|status|logs|kill)
    shift
    exec bash "$REPO_DIR/scripts/$cmd.sh" "$@"
    ;;
  run|monitor|devices|gen|test)
    exec "$BUN" "$REPO_DIR/src/cli.ts" "$@"
    ;;
  ""|help|-h|--help)
    exec "$BUN" "$REPO_DIR/src/cli.ts" help
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Run 'tingtype help' for usage." >&2
    exit 1
    ;;
esac
